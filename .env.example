# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# Local dev (docker compose up): keep the default below.
# Production (Neon): use the POOLED connection string from the Neon dashboard.
#   Pooled URLs contain "-pooler" in the host, end with ?sslmode=require, and
#   are what Prisma runtime queries should use on Vercel.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_lunch_preorder?schema=public"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# NEXTAUTH_URL must match the fully-qualified base URL the browser sees.
#   Local:      http://localhost:3000
#   Production: https://lunch.localbiggerburger.com
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -hex 32   (or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Rotate this if it ever leaks. Must be identical across all server instances.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# OAuth providers (optional — leave blank to disable that provider)
# -----------------------------------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google
#   https://lunch.localbiggerburger.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-in (optional). Leave blank if not using Apple yet.
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Test mode for local dev (sk_test_... / pk_test_...).
# Live mode for production (sk_live_... / pk_live_...).
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret for the endpoint POST /api/stripe/webhook.
# Local: `stripe listen --forward-to localhost:3000/api/stripe/webhook` prints a whsec_...
# Prod:  Stripe Dashboard → Developers → Webhooks → add endpoint
#        https://lunch.localbiggerburger.com/api/stripe/webhook
#        Listen for: checkout.session.completed, checkout.session.async_payment_succeeded
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
# Create at https://resend.com → API Keys. Verify the sending domain
# (localbiggerburger.com) via the DNS records Resend provides (SPF + DKIM).
RESEND_API_KEY="re_..."

# Must be an address on a verified domain in Resend.
EMAIL_FROM="orders@localbiggerburger.com"

# Optional friendly "From" name. If set, emails send as:
#   "LBB Hot Lunch <orders@localbiggerburger.com>"
EMAIL_FROM_NAME="LBB Hot Lunch"

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
# Used to build absolute links in emails + Stripe success/cancel URLs.
#   Local:      http://localhost:3000
#   Production: https://lunch.localbiggerburger.com
APP_BASE_URL="http://localhost:3000"

# Default IANA timezone for schools/orders unless overridden per-school.
DEFAULT_TIMEZONE="America/Los_Angeles"

# -----------------------------------------------------------------------------
# Seed data (used by `npm run prisma:seed` to create the first admin)
# -----------------------------------------------------------------------------
# Change these for production and DO NOT commit real values.
SEED_ADMIN_EMAIL="admin@localbiggerburger.com"
SEED_ADMIN_PASSWORD="change-me-in-production"
